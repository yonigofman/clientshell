{
  "name": "@clientshell/webpack",
  "version": "0.1.0",
  "type": "module",
  "description": "Webpack plugin for clientshell — automatic manifest output and dev stub",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@clientshell/core": "workspace:*"
  },
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "webpack": "^5.0.0"
  }
}
