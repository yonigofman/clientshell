{
  "name": "@clientshell/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for clientshell — generate manifests, validate env vars, create dev stubs",
  "license": "MIT",
  "bin": {
    "clientshell": "./bin/clientshell.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "bin"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@clientshell/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "vitest": "catalog:"
  }
}
