{
  "name": "@clientshell/rollup",
  "version": "0.1.0",
  "type": "module",
  "description": "Rollup plugin for clientshell — automatic manifest output on build",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@clientshell/core": "workspace:*"
  },
  "peerDependencies": {
    "rollup": "^3.0.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "catalog:",
    "tsup": "catalog:",
    "rollup": "^4.0.0"
  }
}
